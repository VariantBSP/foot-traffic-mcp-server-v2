{
  "name": "foot-traffic-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for foot traffic analysis and site selection intelligence using open data sources",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "foot-traffic-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:express --external:node-fetch --external:zod",
    "start": "node dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:@modelcontextprotocol/sdk --external:express --external:node-fetch --external:zod --watch",
    "test": "node dist/index.js --help"
  },
  "keywords": [
    "mcp",
    "foot-traffic",
    "site-selection",
    "location-intelligence",
    "commercial-real-estate"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.3"
  }
}
